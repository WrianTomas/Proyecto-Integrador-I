<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="false">

    <servlet>
        <servlet-name>IncidenciaControlador</servlet-name>
        <servlet-class>com.proyectointegrador.controlador.IncidenciaControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IncidenciaControlador</servlet-name>
        <url-pattern>/api/incidencias</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>LoginControlador</servlet-name>
        <servlet-class>com.proyectointegrador.controlador.LoginControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginControlador</servlet-name>
        <url-pattern>/api/login</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>RegistroControlador</servlet-name>
        <servlet-class>com.proyectointegrador.controlador.RegistroControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroControlador</servlet-name>
        <url-pattern>/api/registro</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>LoginAdminControlador</servlet-name>
        <servlet-class>com.proyectointegrador.controlador.LoginAdminControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginAdminControlador</servlet-name>
        <url-pattern>/api/loginAdmin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EncuestaControlador</servlet-name>
        <servlet-class>com.proyectointegrador.controlador.EncuestaControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EncuestaControlador</servlet-name>
        <url-pattern>/api/encuesta</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

</web-app>